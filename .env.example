# --- Agent API keys (any may be omitted; that agent becomes a labeled stub) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Kimi (Moonshot) and GLM (Zhipu) speak the OpenAI protocol at their own endpoints.
KIMI_API_KEY=
GLM_API_KEY=

# --- Model overrides ---
CLAUDE_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-5.1
GEMINI_MODEL=gemini-2.5-pro
KIMI_MODEL=kimi-k2-0905-preview
GLM_MODEL=glm-4.6

# --- Memory sidecar ---
SIDECAR_PORT=8787
SIDECAR_URL=http://127.0.0.1:8787

# --- Workspace (optional; UI prompts on first launch if unset) ---
COMBINEPRO_WORKSPACE=

# --- Token optimization + editor (editable live in Settings) ---
SKELETON_BYTE_CAP=24000
MAX_FILE_BYTES=512000
DEBOUNCE_SECONDS=1.5
EDITOR_FONT_SIZE=13
